      const [tradeType, setTradeType] = useState('buy');
      const [tradeShares, setTradeShares] = useState(1000);
      const [currentEvent, setCurrentEvent] = useState(null);
      const [eventJumpWarning, setEventJumpWarning] = useState(false); 
      
      const [isMusicPlaying, setIsMusicPlaying] = useState(false);
      const [bgmIndex, setBgmIndex] = useState(0); 
      const [showLeaderboard, setShowLeaderboard] = useState(false);
      const [showEduPanel, setShowEduPanel] = useState(false);
      const [currentTheme, setCurrentTheme] = useState('dark');
      const audioRef = useRef(null);
      const fileInputRef = useRef(null);

      const t = THEMES[currentTheme]; 
      const getDisplayColor = (current, prev) => (current > prev ? t.up : current < prev ? t.down : t.textMuted);
      const getDisplayBgColor = (current, prev) => (current > prev ? t.upBg : current < prev ? t.downBg : t.textMuted);

      const cycleTheme = () => {
        const themeKeys = Object.keys(THEMES);
        const nextIdx = (themeKeys.indexOf(currentTheme) + 1) % themeKeys.length;
        setCurrentTheme(themeKeys[nextIdx]);
      };

      // 1. 抓取歷史數據
      useEffect(() => {
        const fetchAllData = async () => {
          setGameStage('loading');
          try {
            const newData = {};
            let maxDataLength = 0;
            
            const twTime = getTWTime();
            const end = new Date();
            const start = new Date();
            start.setFullYear(start.getFullYear() - 5);
            const endDateStr = new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Taipei' }).format(end);
            const startDateStr = new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Taipei' }).format(start);
            
            for (const stock of STOCK_LIST) {
              setLoadingMsg(`正在下載歷史股價：${stock.name} (${stock.id})...`);
              try {
                const url = `https://api.finmindtrade.com/api/v4/data?dataset=TaiwanStockPrice&data_id=${stock.id}&start_date=${startDateStr}&end_date=${endDateStr}`;
                const response = await fetch(url);
                const json = await response.json();
                if (json.status !== 200 || !json.data) throw new Error("API 回傳錯誤");

                const formattedData = json.data.map(item => ({
                  date: item.date, open: item.open, high: item.max, low: item.min, close: item.close, isReal: true
                }));
                if (formattedData.length === 0) throw new Error("無數據");

                newData[stock.id] = formattedData;
                if (formattedData.length > maxDataLength) maxDataLength = formattedData.length;
              } catch (error) {
                const fakeData = [];
                const d = new Date();
                for(let i=1200; i>=0; i--) {
                  const pastDate = new Date(d);
                  pastDate.setDate(pastDate.getDate() - i);
                  if (pastDate.getDay() !== 0 && pastDate.getDay() !== 6) {
                    fakeData.push({ date: pastDate.toISOString().split('T')[0], open: 100, high: 100, low: 100, close: 100, isReal: false });
                  }
                }
                newData[stock.id] = fakeData;
                if (fakeData.length > maxDataLength) maxDataLength = fakeData.length;
              }
              await new Promise(resolve => setTimeout(resolve, 300));
            }
            
            // ★ 關鍵修正：若今天是交易日，但 FinMind 尚未更新今天的資料(盤中)，手動為每一檔股票新增一筆「今天的 K 線」，後續由 Yahoo 實時報價覆蓋
            const todayStr = `${twTime.getFullYear()}-${String(twTime.getMonth()+1).padStart(2,'0')}-${String(twTime.getDate()).padStart(2,'0')}`;
            const isWeekday = twTime.getDay() >= 1 && twTime.getDay() <= 5;
            
            if (newData['2330'] && newData['2330'].length > 0) {
                const lastDateInFinMind = newData['2330'][newData['2330'].length - 1].date;
                if (isWeekday && lastDateInFinMind !== todayStr) {
                    STOCK_LIST.forEach(stock => {
                        const stockData = newData[stock.id];
                        if (stockData && stockData.length > 0) {
                            const lastCandle = stockData[stockData.length - 1];
                            stockData.push({
                                date: todayStr,
                                open: lastCandle.close,
                                high: lastCandle.close,
                                low: lastCandle.close,
                                close: lastCandle.close,
                                isReal: true
                            });
                        }
                    });
                    maxDataLength += 1;
                }
            }

            setHistoricalData(newData);
            const startIndex = Math.max(0, maxDataLength - 1);
            setDataIndex(startIndex);
            setGameStage('setup');
          } catch (err) {}
        };
        fetchAllData();
      }, []);

      // 判斷是否最新日
      const isLatestDay = historicalData['2330'] && dataIndex >= historicalData['2330'].length - 1;

      // 實時同步邏輯 (每30秒抓取真實數據，完全作廢亂數)
      useEffect(() => {
        if (!isLatestDay || gameStage !== 'playing') {
          setIsRealTimeSync(false);
          setIsMarketOpenNow(false);
          return;
        }
        let isMounted = true;
        const fetchRealTimeQuotes = async () => {
          setIsFetchingLive(true);
          try {
            const twTime = getTWTime();
            const hours = twTime.getHours();
            const minutes = twTime.getMinutes();
            const day = twTime.getDay();
            const isOpen = day >= 1 && day <= 5 && (hours > 9 || (hours === 9 && minutes >= 0)) && (hours < 13 || (hours === 13 && minutes <= 30));
            if (isMounted) setIsMarketOpenNow(isOpen);

            const symbols = STOCK_LIST.map(s => `${s.id}.TW`).join(',');
            // 使用 _t=Date.now() 與 _cb=Date.now() 雙重破解 proxy 快取，保證抓到最新
            const targetUrl = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${symbols}&_t=${Date.now()}`;
            const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(targetUrl)}&_cb=${Date.now()}`;
            
            const res = await fetch(proxyUrl);
            const json = await res.json();
            const parsed = JSON.parse(json.contents);

            if (parsed.quoteResponse && parsed.quoteResponse.result && isMounted) {
              const newLivePrices = {};
              let fetchedTime = null;
              
              setHistoricalData(prevHist => {
                 const updatedHist = { ...prevHist };
                 let histModified = false;
                 
                 parsed.quoteResponse.result.forEach(quote => {
                    const id = quote.symbol.replace('.TW', '');
                    const currentPrice = quote.regularMarketPrice;
                    newLivePrices[id] = currentPrice;
                    
                    if (!fetchedTime && quote.regularMarketTime) {
                      fetchedTime = formatTimeStr(new Date(quote.regularMarketTime * 1000));
                    }
                    
                    // 即時更新今天的 K 線高低點！
                    if (updatedHist[id] && updatedHist[id].length > 0) {
                        const lastIdx = updatedHist[id].length - 1;
                        const todayStr = `${twTime.getFullYear()}-${String(twTime.getMonth()+1).padStart(2,'0')}-${String(twTime.getDate()).padStart(2,'0')}`;
                        if (updatedHist[id][lastIdx].date === todayStr) {
                            updatedHist[id][lastIdx] = {
                                ...updatedHist[id][lastIdx],
                                open: quote.regularMarketOpen || updatedHist[id][lastIdx].open,
                                high: quote.regularMarketDayHigh || currentPrice,
                                low: quote.regularMarketDayLow || currentPrice,
                                close: currentPrice
                            };
                            histModified = true;
                        }
                    }
                 });
                 return histModified ? updatedHist : prevHist;
              });

              setLivePrices(prev => ({...prev, ...newLivePrices}));
              setIsRealTimeSync(true);
              setLastSyncTime(fetchedTime || formatTimeStr(twTime));
            }
          } catch (e) {
            if (isMounted) setIsRealTimeSync(false);
          } finally {
            if (isMounted) setIsFetchingLive(false);
          }
        };
        fetchRealTimeQuotes(); 
        const interval = setInterval(fetchRealTimeQuotes, 30000); 
        return () => { isMounted = false; clearInterval(interval); };
      }, [isLatestDay, gameStage]);

      // 視覺跳動 (真實市場徹底關閉模擬，歷史回測才加亂數)
      useEffect(() => {
        if (!isLive || Object.keys(historicalData).length === 0 || gameStage !== 'playing') return;
        const interval = setInterval(() => {
          setLivePrices(prev => {
            const next = { ...prev };
            STOCK_LIST.forEach(stock => {
              const arr = historicalData[stock.id];
              if (arr && arr[dataIndex]) {
                const dayData = arr[dataIndex];
                if (isLatestDay) {
                  // ★ 最新真實日：絕不加入亂數，直接呈現 Yahoo 每 30 秒抓到的真實股價！
                  next[stock.id] = prev[stock.id] || dayData.close;
                } else {
                  // 歷史回測：隨機漫步模擬
                  const volatility = (Math.random() - 0.5) * 0.008;
                  let newPrice = (prev[stock.id] || dayData.close) * (1 + volatility);
                  newPrice = Math.min(Math.max(newPrice, dayData.low), dayData.high);
                  next[stock.id] = Number(newPrice.toFixed(2));
                }
              }
            });
            return next;
          });
        }, 1500);
        return () => clearInterval(interval);
      }, [isLive, dataIndex, historicalData, gameStage, isLatestDay]);

      // 音樂播放邏輯 (強制使用者互動觸發)
      const toggleMusic = () => {
        if (!audioRef.current) return;
        if (isMusicPlaying) {
          audioRef.current.pause();
          setIsMusicPlaying(false);
        } else {
          audioRef.current.src = BGM_TRACKS[bgmIndex].url;
          audioRef.current.play().then(() => {
            setIsMusicPlaying(true);
          }).catch(e => {
            alert("瀏覽器安全機制阻擋了音樂播放，請隨便點擊網頁其他地方後再試一次！");
            setIsMusicPlaying(false);
          });
        }
      };

      const cycleMusic = () => {
        const nextIdx = (bgmIndex + 1) % BGM_TRACKS.length;
        setBgmIndex(nextIdx);
        if (isMusicPlaying && audioRef.current) {
          audioRef.current.src = BGM_TRACKS[nextIdx].url;
          audioRef.current.play().catch(() => setIsMusicPlaying(false));
        }
      };

      const currentMarket = useMemo(() => {
        if (Object.keys(historicalData).length === 0) return [];
        return STOCK_LIST.map(stock => {
          const dataArray = historicalData[stock.id] || [];
          if (dataArray.length === 0) return { ...stock, price: 0, prevPrice: 0, date: 'N/A', isReal: true };
          const validIndex = Math.min(dataIndex, dataArray.length - 1);
          const todayData = dataArray[validIndex] || { close: 0, open: 0, isReal: true };
          const yesterdayData = validIndex > 0 ? dataArray[validIndex - 1] : todayData;
          const currentPrice = livePrices[stock.id] || todayData.close;
          return { ...stock, price: currentPrice, prevPrice: yesterdayData.close, date: todayData.date || 'N/A', isReal: true };
        });
      }, [historicalData, dataIndex, livePrices]);

      const currentChartData = useMemo(() => {
        if (!historicalData[selectedStockId]) return [];
        return historicalData[selectedStockId].slice(0, dataIndex + 1);
      }, [historicalData, selectedStockId, dataIndex]);

      const selectedStockDetail = currentMarket.find(s => s.id === selectedStockId);
      const currentDateStr = selectedStockDetail?.date || '載入中';
      const activeGroup = groups.find(g => g.id === activeGroupId) || null;

      const getGroupStats = (group) => {
        let stockValue = 0;
        const holdings = Object.entries(group.portfolio).map(([id, data]) => {
          const currentPrice = currentMarket.find(s => s.id === id)?.price || 0;
          const marketValue = data.shares * currentPrice;
          const returnAmount = marketValue - data.totalCost;
          stockValue += marketValue;
          return { id, name: STOCK_LIST.find(s=>s.id===id)?.name, shares: data.shares, avgCost: data.totalCost / data.shares, currentPrice, returnAmount, returnRate: (returnAmount / data.totalCost) * 100 };
        });
        const totalAssets = group.cash + stockValue;
        const safeCap = group.startCap > 0 ? group.startCap : 1; 
        return { holdings, totalAssets, totalReturnRate: ((totalAssets - safeCap) / safeCap) * 100 };
      };

      const activeGroupStats = activeGroup ? getGroupStats(activeGroup) : { holdings: [], totalAssets: 0, totalReturnRate: 0 };
      const leaderboardData = useMemo(() => groups.map(g => ({ ...g, ...getGroupStats(g) })).sort((a, b) => b.totalAssets - a.totalAssets), [groups, currentMarket]);

      // 歷史跳躍防呆
      const executeTimeJump = (targetIndex, confirmMsg) => {
        const hasTraded = groups.some(g => Object.keys(g.portfolio).length > 0 || g.cash !== g.startCap);
        if (hasTraded) {
          if(!window.confirm(confirmMsg || "此操作將會清空所有小組目前的資金與庫存，確定要穿越時空嗎？")) return false;
        }
        setDataIndex(targetIndex); 
        setGroups(prev => prev.map(g => ({ ...g, cash: g.startCap, portfolio: {} })));
        setCurrentEvent(null);
        return true;
      };

      const stepBackTime = (daysAgo) => {
        const targetIdx = Math.max(0, dataIndex - daysAgo);
        executeTimeJump(targetIdx);
      };

      const jumpToEventDate = () => {
        if (!currentEvent) return;
        const targetDate = currentEvent.date;
        const stockData = historicalData['2330'] || [];
        let targetIdx = 0;
        for (let i = 0; i < stockData.length; i++) {
          if (stockData[i].date <= targetDate) targetIdx = i; else break;
        }
        const success = executeTimeJump(targetIdx, `準備跳躍至 ${targetDate}！\n警告：將重置所有小組當前資金與庫存，確定嗎？`);
        if (success) {
          setSelectedStockId(currentEvent.targetId); 
          setEventJumpWarning(true); 
        }
      };

      const advanceTime = (daysToAdvance) => {
        const max = (historicalData['2330'] || []).length;
        if (dataIndex >= max - 1) { alert("已經推演至最新交易日！"); return; }
        setDataIndex(prev => Math.min(prev + daysToAdvance, max - 1));
        setCurrentEvent(null); 
        setEventJumpWarning(false);
      };

      const handleTrade = () => {
        if (!activeGroup || !selectedStockDetail || tradeShares <= 0) return;
        
        const tp = selectedStockDetail.price * tradeShares;
        const tf = Math.max(20, Math.floor(tp * FEE_RATE));
        const tt = tradeType === 'sell' ? Math.floor(tp * TAX_RATE) : 0;
        const tc = tradeType === 'buy' ? tp + tf : tp - tf - tt;

        setGroups(prevGroups => prevGroups.map(g => {
          if (g.id !== activeGroupId) return g;
          if (tradeType === 'buy') {
            if (g.cash < tc) { alert(`${g.name} 餘額不足！`); return g; }
            const cur = g.portfolio[selectedStockId] || { shares: 0, totalCost: 0 };
            return { ...g, cash: g.cash - tc, portfolio: { ...g.portfolio, [selectedStockId]: { shares: cur.shares + tradeShares, totalCost: cur.totalCost + tc } } };
          } else {
            const cur = g.portfolio[selectedStockId] || { shares: 0 };
            if (cur.shares < tradeShares) { alert(`${g.name} 庫存不足！`); return g; }
            const newShares = cur.shares - tradeShares;
            const newPort = { ...g.portfolio };
            if (newShares === 0) delete newPort[selectedStockId];
            else newPort[selectedStockId] = { shares: newShares, totalCost: (cur.totalCost / cur.shares) * newShares };
            return { ...g, cash: g.cash + tc, portfolio: newPort };
          }
        }));
        setTradeShares(1000);
      };

      // 存檔
      const saveLocal = () => { localStorage.setItem('stockCampSave', JSON.stringify({ groups, activeGroupId, dataIndex })); alert('進度已存入本機！'); };
      const loadLocal = () => {
        const data = localStorage.getItem('stockCampSave');
        if (data && window.confirm('確定要載入本機存檔嗎？將覆蓋當前進度。')) {
          const p = JSON.parse(data); setGroups(p.groups || []); setActiveGroupId(p.activeGroupId); setDataIndex(p.dataIndex || 0);
        }
      };
      const exportJSON = () => {
        const a = document.createElement('a');
        a.href = URL.createObjectURL(new Blob([JSON.stringify({ groups, dataIndex, date: currentDateStr }, null, 2)], { type: 'application/json' }));
        a.download = `理財營隊存檔_${currentDateStr}.json`; a.click();
      };
      const importJSON = (e) => {
        const file = e.target.files[0]; if (!file) return;
        const r = new FileReader();
        r.onload = (event) => {
          try {
            const p = JSON.parse(event.target.result);
            if (p.groups) { setGroups(p.groups); setDataIndex(p.dataIndex || 0); if(p.groups.length > 0) setActiveGroupId(p.groups[0].id); alert('讀取成功！'); }
          } catch (err) { alert('讀取失敗！'); }
        };
        r.readAsText(file); e.target.value = null;
      };

      // Setup 畫面邏輯
      const addGroup = () => setTempGroups([...tempGroups, { id: `g${Date.now()}`, name: `第${tempGroups.length + 1}組`, startCap: 1000000 }]);
      const removeGroup = (index) => setTempGroups(tempGroups.filter((_, i) => i !== index));
      const updateGroup = (index, field, value) => { const newG = [...tempGroups]; newG[index][field] = value; setTempGroups(newG); };
      const startGame = () => {
        if (tempGroups.length === 0) return alert("請至少建立一個小組！");
        const initializedGroups = tempGroups.map(g => ({ ...g, cash: g.startCap, portfolio: {} }));
        setGroups(initializedGroups); setActiveGroupId(initializedGroups[0].id);
        const max = historicalData['2330']?.length || 0; setDataIndex(Math.max(0, max - 120)); setGameStage('playing');
      };

      if (gameStage === 'loading') {
        return (
          <div className={`min-h-screen ${t.appBg} flex flex-col items-center justify-center ${t.text} transition-colors duration-700`}>
            <Icon name="RefreshCw" className={`w-14 h-14 ${t.accent} animate-spin mb-6 filter drop-shadow-[0_0_10px_rgba(59,130,246,0.5)]`} />
            <h2 className="text-3xl font-extrabold mb-3 tracking-widest drop-shadow-md">股市夏令營：實戰模擬器</h2>
            <p className={`${t.accent} font-medium animate-pulse text-lg`}>{loadingMsg}</p>
            <div className="w-64 h-1 bg-white/10 rounded-full mt-6 overflow-hidden"><div className={`h-full ${t.btnPrimary} w-2/3 animate-pulse`}></div></div>
          </div>
        );
      }

      if (gameStage === 'setup') {
        return (
          <div className={`min-h-screen ${t.appBg} flex items-center justify-center p-4 transition-colors duration-700`}>
            <div className="absolute top-4 right-4">
              <button onClick={cycleTheme} className={`p-2.5 rounded-xl border ${t.btnSecondary} flex items-center gap-2 shadow-lg hover:-translate-y-1 transition-all`}>
                <Icon name="Palette" className="w-5 h-5"/> <span className="text-sm font-bold">{t.name}</span>
              </button>
            </div>
            <div className={`${t.panel} p-8 md:p-10 rounded-3xl max-w-xl w-full transition-all duration-700`}>
              <div className="text-center mb-8">
                <div className={`w-20 h-20 mx-auto rounded-full ${t.accentBg} flex items-center justify-center mb-4 shadow-inner`}>
                  <Icon name="Users" className={`w-10 h-10 ${t.accent}`} />
                </div>
                <h1 className={`text-3xl font-extrabold ${t.text} mb-2 tracking-wide`}>歡迎來到股市夏令營</h1>
                <p className={t.textMuted}>請設定參與競賽的小組與個別起始資金</p>
              </div>
              <div className={`grid grid-cols-[1fr_1fr_auto] gap-3 mb-2 px-2 text-sm font-bold ${t.accent}`}>
                <div>小組名稱</div><div>起始資金 (元)</div><div></div>
              </div>
              <div className="space-y-3 max-h-[40vh] overflow-y-auto pr-2 custom-scrollbar mb-6">
                {tempGroups.length === 0 && <p className={t.textMuted}>尚未新增小組</p>}
                {tempGroups.map((g, index) => (
                  <div key={g.id} className="flex gap-2 items-center group">
                    <span className={`${t.textMuted} w-5 font-bold`}>{index + 1}.</span>
                    <input type="text" value={g.name} onChange={(e) => updateGroup(index, 'name', e.target.value)} className={`flex-1 rounded-xl p-3 outline-none transition-all ${t.input}`} placeholder="隊名" />
                    <input type="number" value={g.startCap} onChange={(e) => updateGroup(index, 'startCap', Number(e.target.value))} className={`flex-1 rounded-xl p-3 outline-none transition-all font-mono ${t.input}`} placeholder="起始資金" min="1" />
                    <button onClick={() => removeGroup(index)} className={`p-3 opacity-50 hover:opacity-100 hover:text-red-500 transition-all`}><Icon name="X" className="w-5 h-5"/></button>
                  </div>
                ))}
              </div>
              <button onClick={addGroup} className={`w-full py-3 border-2 border-dashed rounded-xl flex items-center justify-center gap-2 font-bold transition-all hover:bg-white/5 ${t.id === 'light' ? 'border-slate-300 text-slate-500' : 'border-slate-700 text-slate-400'}`}>
                + 新增一組
              </button>
              <div className={`mt-8 pt-6 border-t ${currentTheme === 'light' ? 'border-slate-200' : 'border-slate-800'}`}>
                <button onClick={startGame} className={`w-full py-4 rounded-xl font-bold text-xl transition-all hover:scale-[1.02] active:scale-95 ${t.btnPrimary}`}>進入交易大廳！</button>
              </div>
            </div>
          </div>
        );
      }

      // 動態計算 UI 價金避免變數未定義
      const tp = selectedStockDetail ? selectedStockDetail.price * tradeShares : 0;
      const tf = Math.max(20, Math.floor(tp * FEE_RATE));
      const tt = tradeType === 'sell' ? Math.floor(tp * TAX_RATE) : 0;
      const tc = tradeType === 'buy' ? tp + tf : tp - tf - tt;

      return (
        <div className={`min-h-screen ${t.appBg} ${t.text} font-sans pb-10 transition-colors duration-700`}>
          
          {showEduPanel && <EducationPanel t={t} onClose={() => setShowEduPanel(false)} />}
          
          {eventJumpWarning && currentEvent && (
            <div className="fixed inset-0 bg-black/80 z-[60] flex items-center justify-center p-4 backdrop-blur-md animate-fade-in">
              <div className={`${t.modalBg} p-8 rounded-3xl w-full max-w-xl ring-1 ring-purple-500/30 shadow-[0_0_50px_rgba(168,85,247,0.2)]`}>
                <div className="flex items-center gap-4 mb-6 pb-6 border-b border-purple-500/20">
                  <div className="w-16 h-16 bg-purple-500/20 rounded-2xl flex items-center justify-center border border-purple-500/50 shadow-inner">
                    <Icon name="History" className="w-8 h-8 text-purple-400" />
                  </div>
                  <div>
                    <h2 className={`text-3xl font-extrabold ${t.text}`}>{currentEvent.title}</h2>
                    <div className="text-purple-300 font-mono mt-1 font-bold flex items-center gap-2"><Icon name="Calendar" className="w-4 h-4"/> 歷史時間點：{currentEvent.date}</div>
                  </div>
                </div>
                <div className="space-y-4 mb-8">
                  <div className="bg-white/5 p-5 rounded-2xl border border-white/10 shadow-inner">
                    <h3 className="text-sm font-bold text-slate-400 mb-2 flex items-center gap-1">事件背景</h3>
                    <p className={`text-base leading-relaxed ${t.text}`}>{currentEvent.description}</p>
                  </div>
                  <div className="bg-gradient-to-br from-purple-900/40 to-indigo-900/40 p-5 rounded-2xl border border-purple-500/30 shadow-[0_0_15px_rgba(168,85,247,0.1)_inset]">
                    <h3 className="text-sm font-bold text-purple-400 mb-2 flex items-center gap-1"><Icon name="Info" className="w-4 h-4"/> 歷史回顧與影響</h3>
                    <p className="text-purple-100 leading-relaxed text-base">{currentEvent.explanation}</p>
                  </div>
                </div>
                <button onClick={() => setEventJumpWarning(false)} className={`w-full py-4 rounded-xl font-bold text-lg transition-transform active:scale-95 shadow-lg ${t.btnAction}`}>了解！準備決策</button>
              </div>
            </div>
          )}

          {showLeaderboard && (
            <div className="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-md animate-fade-in">
              <div className={`${t.modalBg} p-6 md:p-8 rounded-3xl w-full max-w-2xl ring-1 ring-white/10`}>
                <div className="flex justify-between items-center mb-8">
                  <h2 className="text-3xl font-extrabold text-yellow-500 flex items-center gap-3 drop-shadow-md"><Icon name="Trophy" className="w-8 h-8"/> 營隊英雄榜</h2>
                  <button onClick={() => setShowLeaderboard(false)} className={`p-2 rounded-full hover:bg-white/10 transition-colors ${t.textMuted} hover:${t.text}`}><Icon name="X" className="w-6 h-6"/></button>
                </div>
                <div className="space-y-4 max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar">
                  {leaderboardData.map((g, idx) => (
                    <div key={g.id} className={`flex items-center justify-between p-5 rounded-2xl border transition-all hover:-translate-y-1 ${idx === 0 ? 'bg-gradient-to-r from-yellow-500/20 to-amber-500/10 border-yellow-500/50 shadow-[0_0_15px_rgba(234,179,8,0.2)]' : idx === 1 ? 'bg-slate-400/10 border-slate-400/30' : idx === 2 ? 'bg-orange-500/10 border-orange-500/30' : t.panel}`}>
                      <div className="flex items-center gap-5">
                        <div className={`w-10 h-10 rounded-full flex items-center justify-center text-xl font-bold shadow-inner ${idx === 0 ? 'bg-yellow-500 text-yellow-900' : idx === 1 ? 'bg-slate-300 text-slate-700' : idx === 2 ? 'bg-orange-400 text-orange-900' : 'bg-slate-800/50 text-slate-400'}`}>{idx + 1}</div>
                        <div>
                          <div className={`font-extrabold text-xl ${t.text}`}>{g.name}</div>
                          <div className={`text-sm mt-0.5 ${t.textMuted}`}>本金: {formatMoney(g.startCap)}</div>
                        </div>
                      </div>
                      <div className="text-right">
                        <div className={`font-bold text-2xl tracking-wide ${t.accent}`}>{formatMoney(g.totalAssets)}</div>
                        <div className={`text-base font-bold mt-0.5 px-2 py-0.5 rounded-md inline-block ${g.totalReturnRate >= 0 ? t.upBg : t.downBg}`}>{g.totalReturnRate >= 0 ? '▲' : '▼'} {Math.abs(g.totalReturnRate).toFixed(2)}%</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          <header className={`sticky top-0 z-20 transition-all duration-700 ${t.header}`}>
            <div className="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center p-4 gap-4">
              <div className="flex items-center gap-4">
                <div className={`p-3 rounded-xl shadow-lg flex items-center justify-center text-white ${currentTheme === 'light' ? 'bg-blue-600 shadow-blue-500/30' : currentTheme === 'tech' ? 'bg-cyan-600 shadow-cyan-500/30' : 'bg-blue-600 shadow-blue-900/40'}`}>
                  <Icon name="BarChart2" className="w-7 h-7" />
                </div>
                <div>
                  <h1 className={`text-2xl font-extrabold ${t.text} flex items-center gap-2 tracking-wide drop-shadow-sm`}>
                    股市夏令營
                    {isLatestDay ? (
                      isFetchingLive ? (
                         <span className="flex items-center gap-1 text-blue-400 text-xs ml-2 px-2 py-1 bg-blue-500/10 rounded-md border border-blue-500/30 font-bold"><i className="fa-solid fa-spinner fa-spin"></i> 獲取最新報價中...</span>
                      ) : isMarketOpenNow ? (
                        <span className="flex items-center gap-1 text-emerald-500 text-xs ml-2 px-2 py-1 bg-emerald-500/10 rounded-md border border-emerald-500/50 animate-pulse font-bold"><Icon name="Wifi" className="w-3 h-3" /> 🟢 盤中即時連線 ({lastSyncTime})</span>
                      ) : (
                        <span className="flex items-center gap-1 text-blue-400 text-xs ml-2 px-2 py-1 bg-blue-500/10 rounded-md border border-blue-500/30 font-bold"><Icon name="Clock" className="w-3 h-3" /> 🔵 盤後真實數據 (收盤於 {lastSyncTime})</span>
                      )
                    ) : (
                      <span className="flex items-center gap-1 text-amber-500 text-xs ml-2 px-2 py-1 bg-amber-500/10 rounded-md border border-amber-500/30 font-bold uppercase tracking-wider"><Icon name="History" className="w-3 h-3" /> 🟡 歷史回測 (模擬跳動)</span>
                    )}
                  </h1>
                  <span className={`text-sm flex items-center gap-1.5 mt-1 ${t.accent} font-medium`}>
                    <Icon name="Calendar" className="w-4 h-4"/> 歷史交易日：<span className="text-white bg-black/20 px-2 py-0.5 rounded font-bold tracking-wider">{currentDateStr}</span>
                  </span>
                </div>
              </div>

              <div className="flex items-center gap-2 md:gap-3 flex-wrap justify-end">
                <button onClick={() => setShowEduPanel(true)} className={`p-2 md:px-4 md:py-2.5 rounded-xl border ${t.btnSecondary} flex items-center gap-2 shadow-sm hover:scale-105 transition-all group`} title="開啟學習秘笈">
                  <Icon name="BookOpen" className={`w-5 h-5 ${t.accent} group-hover:scale-110 transition-transform`}/> <span className="font-bold hidden md:inline">學習秘笈</span>
                </button>
                <button onClick={cycleTheme} className={`p-2.5 rounded-xl border ${t.btnSecondary} flex items-center gap-1 shadow-sm hover:scale-105 transition-all`} title="切換主題">
                  <Icon name="Palette" className="w-5 h-5"/>
                </button>
                
                <div className={`flex items-center rounded-xl overflow-hidden border shadow-sm transition-colors ${currentTheme === 'light' ? 'border-slate-300' : 'border-slate-700/50'}`}>
                  <button onClick={toggleMusic} className={`p-2.5 transition-colors border-r ${t.btnSecondary} ${currentTheme === 'light' ? 'border-slate-300' : 'border-slate-700/50'}`} title="音樂開關">
                    {isMusicPlaying ? <Icon name="Music" className={`w-5 h-5 ${t.accent}`}/> : <Icon name="VolumeX" className={`w-5 h-5 ${t.textMuted}`}/>}
                  </button>
                  <button onClick={cycleMusic} className={`p-2.5 transition-colors flex items-center gap-1 ${t.btnSecondary}`} title="切換下一首">
                    <Icon name="SkipForward" className="w-4 h-4" />
                    <span className="text-xs w-16 truncate font-medium">{BGM_TRACKS[bgmIndex].name}</span>
                  </button>
                </div>
                
                <div className={`h-8 w-px mx-1 ${currentTheme === 'light' ? 'bg-slate-300' : 'bg-slate-700/50'}`}></div>

                <button onClick={saveLocal} className={`p-2.5 rounded-xl shadow-sm transition-all hover:scale-105 ${t.btnSecondary}`} title="存檔"><Icon name="Save" className="w-5 h-5"/></button>
                <button onClick={loadLocal} className={`p-2.5 rounded-xl shadow-sm transition-all hover:scale-105 ${t.btnSecondary}`} title="讀檔"><Icon name="RotateCcw" className="w-5 h-5"/></button>
                <label className={`p-2.5 rounded-xl shadow-sm transition-all hover:scale-105 cursor-pointer ${t.btnSecondary}`} title="上傳檔案">
                  <Icon name="Upload" className="w-5 h-5"/><input type="file" accept=".json" className="hidden" ref={fileInputRef} onChange={importJSON} />
                </label>
                <button onClick={exportJSON} className={`p-2.5 rounded-xl shadow-sm transition-all hover:scale-105 ${t.btnSecondary}`} title="下載存檔"><Icon name="Download" className="w-5 h-5"/></button>

                <button onClick={() => setShowLeaderboard(true)} className="ml-1 flex items-center gap-2 bg-gradient-to-r from-yellow-500 to-amber-500 text-white px-4 py-2.5 rounded-xl font-bold shadow-[0_4px_15px_rgba(245,158,11,0.3)] hover:scale-105 transition-transform active:scale-95 border border-yellow-400/50">
                  <Icon name="Trophy" className="w-5 h-5" /> 排行榜
                </button>
              </div>
            </div>
          </header>

          <main className="max-w-7xl mx-auto p-4 grid grid-cols-1 lg:grid-cols-12 gap-6 mt-6">
            <div className="lg:col-span-8 flex flex-col gap-6">
              {/* 控制台 */}
              <div className={`${t.panel} rounded-3xl p-6 relative overflow-hidden flex flex-col gap-5 transition-colors duration-500`}>
                <div className={`flex justify-between items-center border-b pb-4 ${currentTheme === 'light' ? 'border-slate-200' : 'border-slate-800'}`}>
                  <h3 className={`${t.accent} font-extrabold flex items-center gap-2 text-xl tracking-wide`}>
                    <Icon name="Settings" className="w-6 h-6" /> 全域時間推演控制
                  </h3>
                </div>
                
                <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div className={`p-5 rounded-2xl border transition-colors ${currentTheme === 'light' ? 'bg-slate-50 border-slate-200' : 'bg-slate-800/30 border-slate-700/50'}`}>
                    <h4 className={`${t.text} text-sm font-bold mb-4 flex items-center gap-2`}><Icon name="RotateCcw" className="w-4 h-4" /> 1. 隨機回溯 (重置資金)</h4>
                    <div className="flex flex-wrap gap-2">
                      {[ {l:'1個月', v:20}, {l:'半年', v:120}, {l:'1年', v:240} ].map(b => (
                         <button key={b.l} onClick={() => stepBackTime(b.v)} className={`px-3 py-2 rounded-xl text-sm font-medium transition-all hover:scale-105 shadow-sm ${t.btnSecondary}`}>◄ 退 {b.l}</button>
                      ))}
                      <button onClick={() => { const max = historicalData['2330']?.length || 0; executeTimeJump(Math.max(0, max - 1)); }} className={`px-4 py-2 rounded-xl text-sm font-bold transition-all hover:scale-105 shadow-sm ml-auto ${currentTheme === 'light' ? 'bg-blue-100 text-blue-700' : 'bg-blue-900/40 text-blue-300'}`}>最新日</button>
                    </div>
                  </div>

                  <div className={`p-5 rounded-2xl border relative overflow-hidden transition-colors ${currentTheme === 'light' ? 'bg-slate-50 border-slate-200' : 'bg-slate-800/30 border-slate-700/50'}`}>
                    <h4 className={`${t.text} text-sm font-bold mb-4 flex items-center gap-2`}><Icon name="FastForward" className={`w-4 h-4 ${t.accent}`} /> 2. 結算推演 (歷史快轉)</h4>
                    <div className="flex flex-wrap gap-2">
                      {[ {l:'1天', v:1}, {l:'1週', v:5}, {l:'1個月', v:20}, {l:'半年', v:120} ].map((b, i) => (
                        <button key={b.l} onClick={() => advanceTime(b.v)} className={`px-3 py-2 rounded-xl text-sm font-bold transition-all hover:scale-105 shadow-sm flex items-center gap-1 ${i===0 ? t.btnPrimary : t.btnPrimary.replace('from-blue-600', 'from-blue-700').replace('from-cyan-600', 'from-cyan-700')}`}>
                          {i===0 && <Icon name="Play" className="w-3 h-3 fill-current"/>} {b.l}
                        </button>
                      ))}
                    </div>
                  </div>
                </div>

                <div className={`p-5 rounded-2xl border flex flex-col sm:flex-row items-center gap-5 transition-colors ${currentTheme === 'light' ? 'bg-purple-50 border-purple-200' : 'bg-purple-900/20 border-purple-500/30'}`}>
                   <button onClick={() => setCurrentEvent(EVENT_CARDS[Math.floor(Math.random() * EVENT_CARDS.length)])} className={`w-full sm:w-auto px-5 py-3 rounded-xl font-bold flex items-center justify-center gap-2 transition-all hover:scale-105 active:scale-95 shrink-0 ${t.btnAction}`}>
                     <Icon name="Dices" className="w-5 h-5" /> 抽情境卡
                   </button>
                   <div className="flex-1 w-full">
                     {currentEvent ? (
                       <div className="animate-fade-in flex flex-col gap-2">
                         <div className="flex items-center gap-2">
                           <span className={`inline-block px-2 py-1 rounded text-xs font-bold shadow-sm ${currentTheme === 'light' ? 'bg-purple-600 text-white' : 'bg-purple-500/20 text-purple-300 border border-purple-500/30'}`}>{currentEvent.type}</span>
                           <span className={`font-bold ${t.accent}`}>{currentEvent.title}</span>
                         </div>
                         <span className={`font-medium text-sm leading-relaxed ${currentTheme === 'light' ? 'text-purple-900' : 'text-purple-200'}`}>{currentEvent.description}</span>
                         <button onClick={jumpToEventDate} className={`mt-1 self-start px-3 py-1.5 rounded-lg text-xs font-bold transition-all hover:scale-105 flex items-center gap-1 ${t.btnSecondary} border-purple-500/30 hover:border-purple-500 hover:text-purple-400`}>
                           <Icon name="History" className="w-3 h-3"/> 時光機：跳躍至 {currentEvent.date}
                         </button>
                       </div>
                     ) : (
                       <span className={`${t.textMuted} text-sm font-medium`}>點擊抽取情境卡，可讓「時光機」帶領全班跳躍到特定歷史事件發生前夕，進行決策演練！</span>
                     )}
                   </div>
                </div>
              </div>

              {/* K線 */}
              <div className={`${t.panel} rounded-3xl overflow-hidden p-6 transition-colors duration-500`}>
                <div className={`flex justify-between items-end mb-6 border-b pb-4 ${currentTheme === 'light' ? 'border-slate-200' : 'border-slate-800'}`}>
                  <div>
                    <h2 className={`text-2xl font-extrabold ${t.text} flex items-center gap-2 tracking-wide`}>{selectedStockDetail?.name} <span className={t.textMuted}>({selectedStockDetail?.id})</span></h2>
                    <div className="flex items-baseline gap-4 mt-2">
                      <span className={`text-4xl font-black tracking-tight ${getDisplayColor(selectedStockDetail?.price, selectedStockDetail?.prevPrice)}`}>{selectedStockDetail?.price?.toFixed(1) || '0.0'}</span>
                      {selectedStockDetail && selectedStockDetail.prevPrice > 0 && (
                        <span className={`text-sm px-2.5 py-1 rounded-md font-bold ${getDisplayBgColor(selectedStockDetail.price, selectedStockDetail.prevPrice)}`}>
                          {selectedStockDetail.price > selectedStockDetail.prevPrice ? '▲' : '▼'} {Math.abs(selectedStockDetail.price - selectedStockDetail.prevPrice).toFixed(1)} ({(((selectedStockDetail.price - selectedStockDetail.prevPrice) / selectedStockDetail.prevPrice) * 100).toFixed(2)}%)
                        </span>
                      )}
                    </div>
                  </div>
                  <div className={`flex p-1.5 rounded-xl ${currentTheme === 'light' ? 'bg-slate-100 shadow-inner' : 'bg-slate-900 shadow-inner border border-slate-800'}`}>
                    {TIMEFRAMES.map(tf => (
                      <button key={tf.label} onClick={() => setTimeframe(tf.days)} className={`px-4 py-2 text-sm font-bold rounded-lg transition-all ${timeframe === tf.days ? t.btnPrimary : `text-slate-500 hover:${t.text}`}`}>{tf.label}</button>
                    ))}
                  </div>
                </div>
                <div className="relative pl-8 pb-4">
                  <KLineChart data={currentChartData} timeframeDays={timeframe} themeConfig={t} />
                  <div className={`absolute left-0 top-1/2 -rotate-90 text-xs font-bold tracking-widest origin-left ${t.textMuted}`}>股價 (元)</div>
                </div>
              </div>

              {/* 報價清單 */}
              <div className={`${t.panel} rounded-3xl overflow-hidden transition-colors duration-500`}>
                <table className="w-full text-left">
                  <thead className={`${t.tableHead} text-sm transition-colors border-b ${currentTheme === 'light' ? 'border-slate-200' : 'border-slate-800'}`}>
                    <tr><th className="p-5 font-bold uppercase tracking-wider">代號 / 名稱</th><th className="p-5 font-bold text-right uppercase tracking-wider">當日報價</th><th className="p-5 font-bold text-right uppercase tracking-wider">漲跌幅</th></tr>
                  </thead>
                  <tbody className={`divide-y ${currentTheme === 'light' ? 'divide-slate-100' : 'divide-slate-800/50'}`}>
                    {currentMarket.map((stock) => {
                      const change = stock.price - stock.prevPrice;
                      const cr = stock.prevPrice > 0 ? (change / stock.prevPrice) * 100 : 0;
                      return (
                        <tr key={stock.id} onClick={() => setSelectedStockId(stock.id)} className={`${t.tableRow} cursor-pointer relative ${selectedStockId === stock.id ? (currentTheme === 'light' ? 'bg-blue-50' : 'bg-slate-800/50') : ''}`}>
                          <td className="p-5 flex items-center gap-4 pl-6">
                            {selectedStockId === stock.id && <div className={`absolute left-0 top-0 bottom-0 w-1.5 ${currentTheme === 'tech' ? 'bg-cyan-500' : 'bg-blue-500'}`}></div>}
                            <div>
                              <div className={`font-extrabold text-base ${t.text}`}>{stock.name}</div>
                              <div className={`text-xs font-medium mt-0.5 ${t.textMuted}`}>{stock.id}</div>
                            </div>
                          </td>
                          <td className="p-5 text-right">
                            <div className={`text-xl font-bold tracking-wide ${getDisplayColor(stock.price, stock.prevPrice)}`}>{stock.price?.toFixed(1) || '0.0'}</div>
                          </td>
                          <td className="p-5 text-right">
                            <div className={`inline-block px-2.5 py-1 rounded-md text-sm font-bold ${getDisplayBgColor(stock.price, stock.prevPrice)}`}>{change > 0 ? '+' : ''}{cr.toFixed(2)}%</div>
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>

            {/* --- 右側 --- */}
            <div className="lg:col-span-4 flex flex-col gap-6">
              <div className={`rounded-3xl border p-6 shadow-xl transition-colors ${currentTheme === 'light' ? 'bg-gradient-to-br from-blue-50 to-indigo-100 border-blue-200' : 'bg-gradient-to-br from-blue-900/50 to-indigo-900/50 border-blue-700/50 backdrop-blur-xl'}`}>
                <label className={`text-sm font-extrabold mb-3 flex items-center gap-2 tracking-wider ${currentTheme === 'light' ? 'text-blue-800' : 'text-blue-200'}`}><Icon name="Users" className="w-5 h-5"/> 操作小組</label>
                <select value={activeGroupId || ''} onChange={(e) => setActiveGroupId(e.target.value)} className={`w-full rounded-2xl p-4 text-xl font-extrabold focus:ring-4 focus:ring-blue-500/50 outline-none appearance-none transition-colors shadow-sm cursor-pointer ${currentTheme === 'light' ? 'bg-white border border-blue-200 text-blue-900' : 'bg-slate-900/80 border border-blue-500/30 text-white'}`}>
                  {groups.map(g => <option key={g.id} value={g.id}>{g.name}</option>)}
                </select>
                <div className={`mt-5 flex justify-between items-end p-4 rounded-2xl border transition-colors shadow-sm ${currentTheme === 'light' ? 'bg-white/60 border-blue-200' : 'bg-black/20 border-white/5'}`}>
                  <div>
                    <div className={`text-xs font-bold mb-1.5 ${currentTheme === 'light' ? 'text-blue-600' : 'text-blue-300'}`}>該組總資產</div>
                    <div className={`text-2xl font-black tracking-wide ${currentTheme === 'light' ? 'text-blue-950' : 'text-white'}`}>{formatMoney(activeGroupStats.totalAssets)}</div>
                  </div>
                  <div className="text-right">
                    <div className={`text-xs font-bold mb-1.5 ${currentTheme === 'light' ? 'text-blue-600' : 'text-blue-300'}`}>可用現金</div>
                    <div className={`text-xl font-bold ${currentTheme === 'light' ? 'text-emerald-600' : 'text-emerald-400'}`}>{formatMoney(activeGroup?.cash || 0)}</div>
                  </div>
                </div>
              </div>

              <div className={`${t.panel} rounded-3xl p-6 transition-colors duration-500`}>
                <h2 className={`text-xl font-extrabold mb-5 border-b pb-3 ${t.text} ${currentTheme === 'light' ? 'border-slate-200' : 'border-slate-800'}`}>快速下單</h2>
                <div className={`flex rounded-xl overflow-hidden mb-5 border p-1 ${currentTheme === 'light' ? 'bg-slate-100 border-slate-200' : 'bg-slate-900 border-slate-700'}`}>
                  <button className={`flex-1 py-3 font-bold text-base transition-all rounded-lg ${tradeType === 'buy' ? 'bg-red-500 text-white shadow-md shadow-red-500/20' : 'text-slate-500 hover:text-slate-300'}`} onClick={() => setTradeType('buy')}>買進 (Buy)</button>
                  <button className={`flex-1 py-3 font-bold text-base transition-all rounded-lg ${tradeType === 'sell' ? 'bg-green-500 text-white shadow-md shadow-green-500/20' : 'text-slate-500 hover:text-slate-300'}`} onClick={() => setTradeType('sell')}>賣出 (Sell)</button>
                </div>
                <div className="space-y-5">
                  <div>
                    <label className={`text-sm font-bold mb-2 flex justify-between ${t.textMuted}`}>
                      <span>交易股數 (1張 = 1000股)</span>
                      {tradeType === 'sell' && activeGroup && <span className={`${t.accent} cursor-pointer hover:underline`} onClick={() => setTradeShares((activeGroup.portfolio[selectedStockId]?.shares || 0))}>庫存: {activeGroup.portfolio[selectedStockId]?.shares || 0} 股</span>}
                    </label>
                    <div className="flex gap-2">
                      <input type="number" value={tradeShares} onChange={(e) => setTradeShares(Number(e.target.value))} min="1" className={`w-full rounded-xl p-3 text-lg font-bold outline-none transition-colors ${t.input}`} />
                      <button onClick={() => setTradeShares(1000)} className={`px-4 rounded-xl text-sm font-bold whitespace-nowrap transition-all hover:scale-105 ${t.btnSecondary}`}>1張</button>
                    </div>
                  </div>
                  <div className={`p-4 rounded-2xl text-sm space-y-2.5 border transition-colors shadow-inner ${currentTheme === 'light' ? 'bg-slate-50 border-slate-200' : 'bg-slate-950/50 border-slate-800'}`}>
                    <div className={`flex justify-between font-medium ${t.text}`}><span>市價價金</span><span>{formatMoney(tp)}</span></div>
                    <div className={`flex justify-between text-xs ${t.textMuted}`}><span>手續費 (0.1425%)</span><span>{tradeType === 'buy' ? '+' : '-'}{formatMoney(tf)}</span></div>
                    {tradeType === 'sell' && <div className={`flex justify-between text-xs ${t.textMuted}`}><span>交易稅 (0.3%)</span><span>-{formatMoney(tt)}</span></div>}
                    <div className={`h-px my-2 ${currentTheme === 'light' ? 'bg-slate-200' : 'bg-slate-800'}`}></div>
                    <div className={`flex justify-between font-extrabold text-base ${t.text}`}>
                      <span>{tradeType === 'buy' ? '應付交割款' : '可得款項'}</span>
                      <span className={tradeType === 'buy' ? t.accent : (currentTheme === 'light' ? 'text-amber-600' : 'text-amber-400')}>{formatMoney(tc)}</span>
                    </div>
                  </div>
                  <button onClick={handleTrade} className={`w-full py-4 rounded-xl font-bold text-lg shadow-xl transition-all hover:scale-[1.02] active:scale-95 ${tradeType === 'buy' ? 'bg-gradient-to-r from-red-600 to-rose-500 text-white shadow-red-500/30' : 'bg-gradient-to-r from-green-600 to-emerald-500 text-white shadow-green-500/30'}`}>
                    確認{tradeType === 'buy' ? '買進' : '賣出'} {selectedStockDetail?.name}
                  </button>
                </div>
              </div>

              <div className={`${t.panel} rounded-3xl p-6 transition-colors duration-500 flex-1`}>
                <h2 className={`text-xl font-extrabold mb-5 border-b pb-3 ${t.text} ${currentTheme === 'light' ? 'border-slate-200' : 'border-slate-800'}`}>該組庫存狀態</h2>
                {activeGroupStats.holdings.length === 0 ? (
                  <div className={`text-center py-10 flex flex-col items-center ${t.textMuted}`}>
                    <Icon name="Briefcase" className="w-12 h-12 mb-3 opacity-30" />
                    <p className="font-bold">該組目前空手觀望中</p>
                  </div>
                ) : (
                  <div className="space-y-4 max-h-[300px] overflow-y-auto pr-2 custom-scrollbar">
                    {activeGroupStats.holdings.map((h) => (
                      <div key={h.id} className={`p-4 rounded-2xl border transition-colors shadow-sm hover:-translate-y-0.5 ${currentTheme === 'light' ? 'bg-white border-slate-200' : 'bg-slate-800/40 border-slate-700/50'}`}>
                        <div className="flex justify-between items-start mb-3">
                          <div>
                            <div className={`font-extrabold text-lg ${t.text}`}>{h.name}</div>
                            <div className={`text-sm font-medium ${t.textMuted}`}>{h.shares} 股</div>
                          </div>
                          <div className="text-right">
                            <div className={`font-bold tracking-wide ${h.returnAmount >= 0 ? t.up : t.down}`}>{h.returnAmount >= 0 ? '+' : ''}{formatMoney(h.returnAmount)}</div>
                            <div className={`text-xs font-bold px-2 py-1 rounded-md mt-1.5 inline-block ${h.returnAmount >= 0 ? t.upBg : t.downBg}`}>{h.returnRate >= 0 ? '+' : ''}{h.returnRate.toFixed(2)}%</div>
                          </div>
                        </div>
                        <div className={`flex justify-between text-xs font-bold mt-2 border-t pt-3 ${t.textMuted} ${currentTheme === 'light' ? 'border-slate-100' : 'border-slate-700/50'}`}>
                          <span>均價: {h.avgCost.toFixed(1)}</span><span>現價: {h.currentPrice.toFixed(1)}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </main>
        </div>
      );
    };

    // React 18 渲染語法
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
