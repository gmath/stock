      const faClass = ICON_MAP[name] || "fa-solid fa-circle";
      let sizeClass = "text-base";
      if (className.includes("w-14") || className.includes("text-5xl")) sizeClass = "text-5xl";
      else if (className.includes("w-12") || className.includes("text-4xl")) sizeClass = "text-4xl";
      else if (className.includes("w-10") || className.includes("text-3xl")) sizeClass = "text-3xl";
      else if (className.includes("w-8") || className.includes("text-2xl")) sizeClass = "text-2xl";
      else if (className.includes("w-7") || className.includes("text-xl")) sizeClass = "text-xl";
      else if (className.includes("w-6") || className.includes("text-lg")) sizeClass = "text-lg";
      else if (className.includes("w-4") || className.includes("text-sm")) sizeClass = "text-sm";
      else if (className.includes("w-3") || className.includes("text-xs")) sizeClass = "text-xs";
      
      const safeClass = className.replace(/\bw-\d+\b/g, '').replace(/\bh-\d+\b/g, '').replace(/\btext-\w+\b/g, '');
