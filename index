    const KLineChart = ({ data, timeframeDays, themeConfig }) => {
      const containerRef = useRef(null);
      const [dimensions, setDimensions] = useState({ width: 0, height: 250 });

      useEffect(() => {
        const updateSize = () => {
          if (containerRef.current) {
            setDimensions({ width: containerRef.current.offsetWidth, height: 250 });
          }
        };
        window.addEventListener('resize', updateSize);
        updateSize();
        return () => window.removeEventListener('resize', updateSize);
      }, []);

      if (!data || data.length === 0) return <div className={`h-[250px] flex items-center justify-center ${themeConfig.textMuted}`}>暫無資料或載入中...</div>;

      const visibleData = data.slice(-timeframeDays);
      if (visibleData.length === 0) return <div className={`h-[250px] flex items-center justify-center ${themeConfig.textMuted}`}>暫無資料或載入中...</div>;

      const minPrice = Math.min(...visibleData.map(d => d.low));
      const maxPrice = Math.max(...visibleData.map(d => d.high));
      const padding = (maxPrice - minPrice) * 0.05 || maxPrice * 0.05; 
      const yMin = minPrice - padding;
      const yMax = maxPrice + padding;
      const yRange = yMax - yMin || 1; 

      const mapY = (price) => dimensions.height - ((price - yMin) / yRange) * dimensions.height;
      const candleWidth = Math.max((dimensions.width / visibleData.length) * 0.6, 1);
      const spacing = dimensions.width / visibleData.length;

      return (
        <div ref={containerRef} className={`w-full h-[250px] relative border-b border-l ${themeConfig.id === 'light' ? 'border-slate-300' : themeConfig.id === 'tech' ? 'border-indigo-600/50' : 'border-slate-700/50'}`}>
          <svg width={dimensions.width} height={dimensions.height} className="overflow-visible">
            {[0, 0.25, 0.5, 0.75, 1].map(ratio => {
              const price = yMin + yRange * ratio;
              const y = mapY(price);
              return (
                <g key={ratio}>
                  <line x1="0" y1={y} x2={dimensions.width} y2={y} stroke={themeConfig.klineGrid} strokeDasharray="4 4" opacity="0.5"/>
                  <text x="-5" y={y + 4} fill={themeConfig.klineText} fontSize="10" textAnchor="end">{price.toFixed(1)}</text>
                </g>
              );
            })}

            {visibleData.map((d, i) => {
              const x = i * spacing + spacing / 2;
              const isUp = d.close >= d.open;
              const color = isUp ? (themeConfig.id === 'tech' ? '#fb7185' : (themeConfig.id === 'light' ? '#dc2626' : '#ef4444')) : (themeConfig.id === 'tech' ? '#34d399' : (themeConfig.id === 'light' ? '#16a34a' : '#22c55e'));
              const yTop = mapY(Math.max(d.open, d.close));
              const yBottom = mapY(Math.min(d.open, d.close));
              const candleHeight = Math.max(yBottom - yTop, 1);

              return (
                <g key={d.date + i} className="hover:opacity-80 transition-opacity">
                  <line x1={x} y1={mapY(d.high)} x2={x} y2={mapY(d.low)} stroke={color} strokeWidth={1} />
                  <rect x={x - candleWidth / 2} y={yTop} width={candleWidth} height={candleHeight} fill={color} rx={candleWidth > 4 ? 1 : 0} />
                  <title>{`日期: ${d.date}\n開: ${d.open.toFixed(1)}\n高: ${d.high.toFixed(1)}\n低: ${d.low.toFixed(1)}\n收: ${d.close.toFixed(1)}`}</title>
                </g>
              );
            })}
          </svg>
        </div>
      );
    };

    // ==========================================
